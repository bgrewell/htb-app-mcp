# HackTheBox API token.
#
# Generate one at: https://app.hackthebox.com/profile/settings
# (Profile Settings -> App Tokens -> Create App Token)
#
# Tokens are JWT-formatted, long-lived, and grant the same access as your
# logged-in browser session. Treat as a secret. Never commit.
HTB_API_KEY=

# Optional: override the API base URL (defaults to https://labs.hackthebox.com/api/v4)
# HTB_API_BASE_URL=https://labs.hackthebox.com/api/v4

# Optional: per-request timeout in seconds (default 30)
# HTB_HTTP_TIMEOUT=30

# Optional: log level (debug, info, warn, error). Default info.
# HTB_LOG_LEVEL=info
